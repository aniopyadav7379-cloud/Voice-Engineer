ENVIRONMENT=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://voiceplat:voiceplat@postgres:5432/voiceplat
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ISSUER=voice-platform
ACCESS_TOKEN_TTL_SECONDS=3600

DEFAULT_RATE_LIMIT_CAPACITY=50
DEFAULT_RATE_LIMIT_REFILL_PER_SEC=5.0

PROVIDER_TIMEOUT_SECONDS=8.0
PROVIDER_FAILURE_THRESHOLD=3
PROVIDER_CIRCUIT_RESET_SECONDS=30

# ":memory:" needs no server (embedded Qdrant, good for local dev without
# docker-compose). docker-compose overrides this to http://qdrant:6333.
QDRANT_LOCATION=:memory:
MEMORY_TOP_K=3

# Leave any of these blank to skip that provider — the router always
# falls back to the built-in mock provider so the gateway still runs.
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
