# Base URL of the deployed gateway (no trailing slash), e.g.
# https://voice-platform-gateway.onrender.com
NEXT_PUBLIC_API_URL=https://voice-platform-gateway.onrender.com

# WebSocket URL for the voice pipeline. Same host as the API, wss:// scheme.
NEXT_PUBLIC_WS_URL=wss://voice-platform-gateway.onrender.com
